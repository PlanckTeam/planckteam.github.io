---
import { Icon } from "astro-icon/components";
import HeaderLink from "./HeaderLink.astro";
import ThemeToggle from "./ThemeToggle.astro";
---

<aside
    class="mobile-sidebar"
    id="mobile-sidebar"
    aria-label="Mobile navigation"
>
    <!-- Backdrop overlay -->
    <div class="backdrop" data-sidebar-close></div>

    <!-- Sidebar panel -->
    <nav class="sidebar-panel">
        <button
            class="close-btn"
            data-sidebar-close
            aria-label="Close navigation menu"
        >
            <Icon name="mdi:close" width="32" height="32" aria-hidden="true" />
        </button>

        <div class="sidebar-content">
            <div class="nav-links">
                <HeaderLink href="/">Home</HeaderLink>
                <HeaderLink href="/about">About us</HeaderLink>
                <HeaderLink href="/fll">FLL</HeaderLink>
                <HeaderLink href="/ftc">FTC</HeaderLink>
                <HeaderLink href="/blog">Blog</HeaderLink>
            </div>

            <div class="sidebar-divider"></div>

            <div class="social-links">
                <a
                    href="https://www.instagram.com/planckteam"
                    target="_blank"
                    aria-label="Instagram"
                >
                    <Icon
                        name="mdi:instagram"
                        width="28"
                        height="28"
                        aria-hidden="true"
                    />
                </a>
                <a
                    href="https://www.facebook.com/planckteam"
                    target="_blank"
                    aria-label="Facebook"
                >
                    <Icon
                        name="mdi:facebook"
                        width="28"
                        height="28"
                        aria-hidden="true"
                    />
                </a>
                <a
                    href="https://www.linkedin.com/company/planck-team-italy"
                    target="_blank"
                    aria-label="LinkedIn"
                >
                    <Icon
                        name="mdi:linkedin"
                        width="28"
                        height="28"
                        aria-hidden="true"
                    />
                </a>
                <a
                    href="https://www.youtube.com/@PlanckTeam5777"
                    target="_blank"
                    aria-label="YouTube"
                >
                    <Icon
                        name="mdi:youtube"
                        width="28"
                        height="28"
                        aria-hidden="true"
                    />
                </a>
                <a
                    href="https://github.com/PlanckTeam"
                    target="_blank"
                    aria-label="GitHub"
                >
                    <Icon
                        name="mdi:github"
                        width="28"
                        height="28"
                        aria-hidden="true"
                    />
                </a>
            </div>

            <div class="sidebar-divider"></div>

            <ThemeToggle />
        </div>
    </nav>
</aside>

<style>
    .mobile-sidebar {
        display: none;
    }

    .backdrop {
        position: fixed;
        inset: 0;
        z-index: 998;
        background: rgba(0, 0, 0, 0.5);
        opacity: 0;
        transition: opacity 0.3s ease;
        pointer-events: none;
    }

    .sidebar-panel {
        position: fixed;
        top: 0;
        right: 0;
        z-index: 999;
        width: min(320px, 80vw);
        height: 100dvh;
        background: var(--bg-surface, #fff);
        box-shadow: -4px 0 16px rgba(var(--black), 15%);
        transform: translateX(100%);
        transition: transform 0.3s ease;
        display: flex;
        flex-direction: column;
        overflow-y: auto;

        .dark & {
            background: var(--bg-surface, #161b22);
        }
    }

    /* Open state */
    .mobile-sidebar.open {
        display: block;

        .backdrop {
            opacity: 1;
            pointer-events: auto;
        }

        .sidebar-panel {
            transform: translateX(0);
        }
    }

    .close-btn {
        align-self: flex-end;
        border: 0;
        background: none;
        cursor: pointer;
        color: rgb(var(--black));
        padding: 1em;
    }

    .sidebar-content {
        padding: 0 1.5em 2em;
        display: flex;
        flex-direction: column;
        gap: 1.5em;
    }

    .nav-links {
        display: flex;
        flex-direction: column;
        gap: 0.25em;

        :global(a) {
            padding: 0.75em 0;
            font-size: 1.1em;
            color: rgb(var(--black));
            text-decoration: none;
            border-bottom: 2px solid transparent;
            transition:
                border-color 0.2s,
                color 0.2s;
        }

        :global(a.active) {
            border-bottom-color: var(--accent);
            color: var(--accent);
        }

        :global(a):hover {
            color: var(--accent);
        }
    }

    .sidebar-divider {
        height: 1px;
        background: rgb(var(--gray-light));
    }

    .social-links {
        display: flex;
        gap: 0.75em;
        flex-wrap: wrap;

        a {
            display: flex;
            align-items: center;
            justify-content: center;
            width: 40px;
            height: 40px;
            border-radius: 8px;
            color: rgb(var(--gray));
            text-decoration: none;
            transition:
                background 0.2s,
                color 0.2s;
        }

        a:hover {
            background: rgb(var(--gray-light));
            color: var(--accent);

            .dark & {
                background: rgba(var(--gray-light), 10%);
            }
        }
    }

    /* Show only on mobile */
    @media (min-width: 721px) {
        .mobile-sidebar,
        .mobile-sidebar.open {
            display: none !important;
        }
    }
</style>

<script>
    const sidebar = document.getElementById("mobile-sidebar");
    const html = document.documentElement;

    function openSidebar() {
        if (!sidebar) return;
        sidebar.classList.add("open");
        html.style.overflow = "hidden";
    }

    function closeSidebar() {
        if (!sidebar) return;
        sidebar.classList.remove("open");
        html.style.overflow = "";
    }

    declare global {
        interface Window {
            __openMobileSidebar: typeof openSidebar;
            __closeMobileSidebar: typeof closeSidebar;
        }
    }

    // Expose functions globally so the hamburger button in Header can call them
    window.__openMobileSidebar = openSidebar;
    window.__closeMobileSidebar = closeSidebar;

    // Close on backdrop click or close button
    sidebar?.addEventListener("click", (e) => {
        const target = e.target as HTMLElement;
        if (target.closest("[data-sidebar-close]")) {
            closeSidebar();
        }
    });

    // Close on Escape key
    document.addEventListener("keydown", (e) => {
        if (e.key === "Escape" && sidebar?.classList.contains("open")) {
            closeSidebar();
        }
    });
</script>
